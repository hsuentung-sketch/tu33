# ============================================================
# ERP LINE Bot — 環境變數範本
# ============================================================
# 用途：複製此檔為 .env.<company>（例：.env.company-b），填完後：
#   Get-Content .env.company-b | fly secrets import
#
# 欄位分三類：
#   [必填]   沒填服務會起不來或主要功能壞掉
#   [選配]   有對應功能才需要
#   [自動]   Fly / 執行環境會給，自己別填
# ============================================================

# ---------- 資料庫（Supabase）[必填] ----------
# 從 Supabase → Project Settings → Database → Connection string 抓
# DATABASE_URL 走 pooler（port 6543）給 runtime 用
# DIRECT_URL 走 direct（port 5432）給 prisma migrate 用
DATABASE_URL=postgresql://postgres.xxxxx:<password>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxxx:<password>@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ---------- Supabase Storage（產品文件 PDS/SDS/DM）[必填] ----------
# SUPABASE_URL 必須是 https://<project-ref>.supabase.co，不是 supabase.com
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role key, NOT anon key>
SUPABASE_PRODUCT_DOCS_BUCKET=product-docs

# ---------- LINE Messaging API [必填] ----------
# 從 LINE Developers Console → Messaging API channel 抓
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ---------- JWT（後台登入 + PDF 短連結簽章）[必填] ----------
# 隨機 32+ 字元字串。換了會讓所有後台 session 與 PDF 連結立刻失效
JWT_SECRET=<openssl rand -hex 32 產生>
JWT_EXPIRES_IN=7d

# ---------- 對外 URL（PDF / 短連結要用）[必填] ----------
# Fly 預設：https://<app-name>.fly.dev
PUBLIC_BASE_URL=https://erp-line-bot.fly.dev

# ---------- Email（每日備份 + 月結對帳單寄送）[選配] ----------
# Gmail 需先啟用 2FA 再產「應用程式密碼」當 SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ERP <noreply@example.com>
BACKUP_EMAIL_TO=admin@example.com

# ---------- AI 功能 [選配] ----------
# 語音開單（Whisper）
OPENAI_API_KEY=
# 名片 OCR
GOOGLE_VISION_API_KEY=
# 語音指令解析（Claude Haiku）
ANTHROPIC_API_KEY=

# ---------- 執行環境 [自動，別改] ----------
# NODE_ENV 由 fly.toml 設 production
# PORT 由 fly.toml 設 3000（別從 Render 的 .env 抄 PORT=10000 過來）
# FLY_MACHINE_VERSION 由 Fly 自動注入，給版本顯示用
