PORT=3000
NODE_ENV=development

# Database (PostgreSQL with pg_trgm extension)
DATABASE_URL="postgresql://user:password@localhost:5432/erp?schema=public"

# LINE Bot (default channel — each tenant can override)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# OpenAI (Whisper for voice-to-text)
OPENAI_API_KEY=

# Google Cloud Vision (Business card OCR)
GOOGLE_VISION_API_KEY=

# Anthropic (Claude Haiku for voice command parsing)
ANTHROPIC_API_KEY=
