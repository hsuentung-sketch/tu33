# ============================================================
# ERP LINE Bot — 本機開發用 .env 範本
# ============================================================
# 用途：cp .env.example .env，然後修改必要欄位
# 生產部署用 .env.template（Supabase + Fly.io 導向）
# ============================================================

PORT=3000
NODE_ENV=development

# ---------- 資料庫（Docker Compose dev）----------
# 對應 docker-compose.dev.yml（port 5433）
DATABASE_URL="postgresql://erp:erp_dev_password@localhost:5433/erp_dev?schema=public"

# ---------- LINE Bot（本機可留空）----------
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ---------- JWT ----------
JWT_SECRET=dev-only-secret-change-me
JWT_EXPIRES_IN=7d

# ---------- 對外 URL（PDF 短連結用）----------
PUBLIC_BASE_URL=http://localhost:3000

# ---------- Email（本機可留空）----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ---------- Supabase Storage（產品文件，本機可留空）----------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRODUCT_DOCS_BUCKET=product-docs

# ---------- AI 功能（本機可留空）----------
OPENAI_API_KEY=
GOOGLE_VISION_API_KEY=
ANTHROPIC_API_KEY=
