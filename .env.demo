# ===== Demo 環境設定 =====
# 複製此檔案為 .env 並修改相關設定
# Copy this file to .env and modify as needed

# 應用設定
NODE_ENV=demo
PORT=3000

# ===== Database (PostgreSQL with pg_trgm extension) =====
# 本地開發：
# DATABASE_URL="postgresql://user:password@localhost:5432/erp_demo?schema=public"

# Fly.io Postgres：
# DATABASE_URL="postgresql://postgres:PASSWORD@erp-demo-db.internal:5432/postgres?schema=public"

DATABASE_URL="postgresql://user:password@localhost:5432/erp_demo?schema=public"

# ===== LINE Bot (可選，演示時可留空) =====
# Default channel — each tenant can override
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ===== JWT (必須在生產環境設定安全值) =====
# 生成方式：openssl rand -hex 32
JWT_SECRET=demo-secret-change-in-production
JWT_EXPIRES_IN=7d

# ===== Email (SMTP，演示時可留空) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ===== AI & Vision APIs (演示時可留空) =====
# OpenAI (Whisper for voice-to-text)
OPENAI_API_KEY=

# Google Cloud Vision (Business card OCR)
GOOGLE_VISION_API_KEY=

# Anthropic (Claude for voice command parsing)
ANTHROPIC_API_KEY=
