generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

// ============================================================
// Multi-Tenant
// ============================================================

model Tenant {
  id                String   @id @default(cuid())
  companyName       String
  taxId             String?  // 統一編號
  lineChannelId     String?  @unique
  lineChannelSecret String?
  lineAccessToken   String?
  logo              String?
  address           String?
  phone             String?
  email             String?
  modules           String[] // ["sales","purchase","accounting"]
  settings          Json     @default("{}")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  employees      Employee[]
  products       Product[]
  customers      Customer[]
  suppliers      Supplier[]
  quotations     Quotation[]
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  receivables    AccountReceivable[]
  payables       AccountPayable[]
  auditLogs      AuditLog[]
  inventories    Inventory[]
  inventoryTxns  InventoryTransaction[]
  einvoices          Einvoice[]
  einvoiceNumberPools EinvoiceNumberPool[]
  allowances         EinvoiceAllowance[]
  chartOfAccounts    ChartOfAccount[]
  fiscalPeriods      FiscalPeriod[]
  journalEntries     JournalEntry[]
}

// ============================================================
// Core: Employee & Auth
// ============================================================

model Employee {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  lineUserId String?  @unique
  employeeId String
  name       String
  phone      String?
  email      String?
  address    String?
  role       Role     @default(VIEWER)
  // bcrypt hash for the admin web console. Null = no web access (LINE-only user).
  passwordHash String?
  // Timestamp when passwordHash was last set; surfaced in admin UI so ADMIN
  // can see which employees have a live web login and when it was last rotated.
  passwordSetAt DateTime?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, employeeId])
  @@index([tenantId])
}

enum Role {
  ADMIN
  SALES
  PURCHASING
  ACCOUNTING
  VIEWER
}

// ============================================================
// Master: Product
// ============================================================

model Product {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  code      String
  name      String
  category  String?
  salePrice Decimal  @db.Decimal(12, 2)
  costPrice Decimal  @db.Decimal(12, 2)
  note      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory     Inventory?
  inventoryTxns InventoryTransaction[]
  documents     ProductDocument[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ============================================================
// Master: Product Documents (PDS / SDS / DM / etc.)
// ============================================================

model ProductDocument {
  id          String      @id @default(cuid())
  tenantId    String
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        DocumentType
  fileName    String      // original filename for display
  storagePath String      // path inside the storage bucket
  fileSize    Int         // bytes
  mimeType    String
  uploadedBy  String?     // employee id
  createdAt   DateTime    @default(now())

  @@index([tenantId])
  @@index([productId, type])
}

enum DocumentType {
  PDS
  SDS
  DM
  OTHER
}

// ============================================================
// Master: Customer
// ============================================================

model Customer {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  contactName String?
  taxId       String?
  phone       String?
  zipCode     String?
  address     String?
  paymentDays Int      @default(30)
  lineUserId  String?
  email       String?
  grade       String?  @default("B") // A/B/C
  tags        String[] // industry tags
  // Employee id of whoever created this customer. Used to scope SALES
  // visibility: sales users only see customers they created; ADMIN
  // sees all. Nullable for legacy data and system-created records.
  createdBy   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotations  Quotation[]
  salesOrders SalesOrder[]
  receivables AccountReceivable[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ============================================================
// Master: Supplier
// ============================================================

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  type        String?
  contactName String?
  taxId       String?
  phone       String?
  zipCode     String?
  address     String?
  paymentDays Int      @default(60)
  email       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  payables       AccountPayable[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ============================================================
// Sales: Quotation + Tracking
// ============================================================

model Quotation {
  id             String          @id @default(cuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  quotationNo    String
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  salesPerson    String
  salesPhone     String?
  subtotal       Decimal         @db.Decimal(12, 2)
  taxAmount      Decimal         @db.Decimal(12, 2)
  totalAmount    Decimal         @db.Decimal(12, 2)
  supplyTime     String?
  paymentTerms   String?
  validUntil     String?
  note           String?
  status         QuotationStatus @default(DRAFT)
  dealClosed     Boolean?
  trackingNote   String?
  version        Int             @default(1)
  createdBy      String
  isDeleted      Boolean         @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items      QuotationItem[]
  salesOrder SalesOrder?

  @@unique([tenantId, quotationNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, isDeleted])
}

model QuotationItem {
  id             String   @id @default(cuid())
  quotationId    String
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productName    String
  quantity       Int
  unitPrice      Decimal  @db.Decimal(12, 2)
  amount         Decimal  @db.Decimal(12, 2)
  note           String?
  suggestedPrice Decimal? @db.Decimal(12, 2)
  sortOrder      Int      @default(0)
}

enum QuotationStatus {
  DRAFT
  SENT
  TRACKING
  WON
  LOST
  CANCELLED
}

// ============================================================
// Sales: Sales Order + Record
// ============================================================

model SalesOrder {
  id           String      @id @default(cuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  orderNo      String
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  quotationId  String?     @unique
  quotation    Quotation?  @relation(fields: [quotationId], references: [id])
  salesPerson  String
  salesPhone   String?
  deliveryNote String?
  subtotal     Decimal     @db.Decimal(12, 2)
  taxAmount    Decimal     @db.Decimal(12, 2)
  totalAmount  Decimal     @db.Decimal(12, 2)
  status       SalesStatus @default(PENDING)
  orderDate    DateTime    @default(now())
  deliveryDate DateTime?
  deliveredBy  String?
  receivedBy   String?
  createdBy    String
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items      SalesItem[]
  receivable AccountReceivable?
  einvoices  Einvoice[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, isDeleted])
}

model SalesItem {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productName  String
  quantity     Int
  unitPrice    Decimal    @db.Decimal(12, 2)
  amount       Decimal    @db.Decimal(12, 2)
  note         String?
  sortOrder    Int        @default(0)
}

enum SalesStatus {
  PENDING
  DELIVERED
  COMPLETED
}

// ============================================================
// Purchase: Purchase Order + Record
// ============================================================

model PurchaseOrder {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  orderNo       String
  supplierId    String
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  internalStaff String
  staffPhone    String?
  deliveryNote  String?
  subtotal      Decimal        @db.Decimal(12, 2)
  taxAmount     Decimal        @db.Decimal(12, 2)
  totalAmount   Decimal        @db.Decimal(12, 2)
  status        PurchaseStatus @default(PENDING)
  orderDate     DateTime       @default(now())
  receivedDate  DateTime?
  createdBy     String
  isDeleted     Boolean        @default(false)
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  items   PurchaseItem[]
  payable AccountPayable?

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, supplierId])
  @@index([tenantId, isDeleted])
}

model PurchaseItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productName      String
  quantity         Int
  unitPrice        Decimal       @db.Decimal(12, 2)
  amount           Decimal       @db.Decimal(12, 2)
  note             String?
  referenceCost    Decimal?      @db.Decimal(12, 2)
  lastPurchaseDate DateTime?
  sortOrder        Int           @default(0)
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  COMPLETED
}

// ============================================================
// Accounting: Accounts Receivable
// ============================================================

model AccountReceivable {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id])
  salesOrderId String     @unique
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  billingMonth Int
  billingYear  Int
  amount       Decimal    @db.Decimal(12, 2)
  dueDate      DateTime
  isPaid       Boolean    @default(false)
  paidDate     DateTime?
  invoiceNo    String?
  note         String?
  einvoice     Einvoice?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId])
  @@index([tenantId, isPaid])
  @@index([tenantId, dueDate])
}

// ============================================================
// Accounting: Accounts Payable
// ============================================================

model AccountPayable {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id])
  purchaseOrderId String        @unique
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  billingMonth    Int
  billingYear     Int
  amount          Decimal       @db.Decimal(12, 2)
  dueDate         DateTime
  isPaid          Boolean       @default(false)
  paidDate        DateTime?
  invoiceNo       String?
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([tenantId, isPaid])
  @@index([tenantId, dueDate])
}

// ============================================================
// Core: Audit Log
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String
  action    String
  entity    String
  entityId  String
  detail    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, entity, entityId])
  @@index([createdAt])
}

// ============================================================
// Inventory
// ============================================================

model Inventory {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  productId     String   @unique
  product       Product  @relation(fields: [productId], references: [id])
  quantity      Int      @default(0)
  reorderPoint  Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, productId])
  @@index([tenantId])
  @@index([tenantId, productId])
}

model InventoryTransaction {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  productId String
  product   Product           @relation(fields: [productId], references: [id])
  delta     Int
  reason    InventoryReason
  refType   String?
  refId     String?
  note      String?
  createdBy String?
  createdAt DateTime          @default(now())

  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, refType, refId])
}

enum InventoryReason {
  SALES_OUT
  PURCHASE_IN
  ADJUSTMENT
  INITIAL
}

// ============================================================
// Short Links (for LINE-friendly download URLs)
// ============================================================

// A short opaque code that resolves to a full download URL. Lets us
// send "https://host/s/AX7B2K" in LINE instead of 150-char JWT links.
// The target is stored as-is (e.g. a /pdf/:kind/:id?token=... URL);
// /s/:code simply 302-redirects to it. The underlying JWT still guards
// the resource, so short-link rows themselves are not secrets.
model ShortLink {
  id        String    @id @default(cuid())
  code      String    @unique
  tenantId  String?
  target    String    @db.Text
  label     String?
  kind      String?
  expiresAt DateTime?
  hits      Int       @default(0)
  createdBy String?
  createdAt DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([expiresAt])
}

// ============================================================
// Error Log (runtime exceptions, surfaced in admin "異常紀錄")
// ============================================================

model ErrorLog {
  id         String   @id @default(cuid())
  tenantId   String?                      // null for pre-auth errors
  userId     String?                      // null for anonymous / cron
  level      String   @default("error")   // error | warn
  source     String                       // "line.webhook", "api.products", "pdf.router", ...
  message    String   @db.Text
  stack      String?  @db.Text
  requestId  String?                      // correlation id (if set by middleware)
  route      String?                      // e.g. "POST /api/products"
  statusCode Int?
  context    Json?                        // arbitrary structured extras
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@index([level, createdAt])
}

// ============================================================
// E-Invoice (Taiwan 財政部電子發票 MIG 3.2.1 via Turnkey)
// ============================================================

// 電子發票字軌 / 配號區間。每兩個月一批，由 ADMIN 從國稅局核定通知書
// 複製進來。`nextNumber` 於 `allocateNumber()` 交易內遞增；耗盡時
// `nextNumber > rangeEnd`，isActive 自動停用由呼叫方處理。
model EinvoiceNumberPool {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  yearMonth   String   // e.g. "11311" = 民國 113 年 11-12 月期
  trackAlpha  String   // 字軌兩碼 e.g. "AB"
  rangeStart  Int      // 00000000 - 99999999
  rangeEnd    Int
  nextNumber  Int
  isActive    Boolean  @default(true)
  note        String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, isActive])
}

// 單張電子發票主檔。與 AccountReceivable 1:1、SalesOrder N:1（同一銷貨單
// 在作廢後可重開一張，故 salesOrderId 不 unique；receivableId unique）。
model Einvoice {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceNo     String    // "AB12345678"
  invoiceDate   DateTime
  buyerTaxId    String?   // null → XML 輸出時填 "0000000000"
  buyerName     String
  buyerAddress  String?
  salesAmount   Decimal   @db.Decimal(14, 2)
  taxAmount     Decimal   @db.Decimal(14, 2)
  totalAmount   Decimal   @db.Decimal(14, 2)
  taxType       String    @default("1") // 1=應稅 2=零稅率 3=免稅
  status        String    @default("issued") // issued|uploaded|confirmed|rejected|voided
  voidedAt      DateTime?
  voidReason    String?
  xmlPath       String?   // 寫到 Turnkey inbound 目錄後的檔名（絕對路徑）
  voidXmlPath   String?
  uploadedAt    DateTime?
  confirmedAt   DateTime?
  rejectReason  String?

  receivableId  String?   @unique
  receivable    AccountReceivable? @relation(fields: [receivableId], references: [id])
  salesOrderId  String?
  salesOrder    SalesOrder? @relation(fields: [salesOrderId], references: [id])

  items         EinvoiceItem[]
  allowances    EinvoiceAllowance[]
  /** 4 碼隨機碼，B2C 證明聯 QR 驗證會用到 */
  randomCode    String?
  /** 載具類別代碼：3J0002=手機條碼 CQ0001=自然人憑證 EJ0113=會員載具（依財政部） */
  carrierType   String?
  /** 載具 ID（手機條碼 8 碼 / 憑證 16 碼 / 會員自訂） */
  carrierId     String?
  /** 捐贈碼（3-7 碼數字）— NPOBAN */
  npoban        String?
  /** 列印註記 Y=列印證明聯 N=不列印（載具或捐贈時 N） */
  printFlag     String   @default("Y")
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, status])
  @@index([tenantId, invoiceDate])
}

model EinvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Einvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sequence    Int
  description String
  quantity    Decimal  @db.Decimal(14, 4)
  unit        String?
  unitPrice   Decimal  @db.Decimal(14, 4)
  amount      Decimal  @db.Decimal(14, 2)
}

// 折讓單 D0401（賣方開立）/ D0501（賣方作廢折讓）。
// 一張電子發票可對應多張折讓單（部分折讓）。
model EinvoiceAllowance {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  allowanceNo     String   // 折讓單號（自訂 YYYYMMDD + seq）
  allowanceDate   DateTime
  /** seller=賣方開立 buyer=買方開立（本系統目前只做 seller） */
  type            String   @default("seller")
  invoiceId       String
  invoice         Einvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  salesAmount     Decimal  @db.Decimal(14, 2)
  taxAmount       Decimal  @db.Decimal(14, 2)
  totalAmount     Decimal  @db.Decimal(14, 2)
  reason          String?
  status          String   @default("issued") // issued|confirmed|voided
  xmlPath         String?
  voidXmlPath     String?
  voidedAt        DateTime?
  voidReason      String?
  items           EinvoiceAllowanceItem[]
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, allowanceNo])
  @@index([tenantId, status])
  @@index([invoiceId])
}

model EinvoiceAllowanceItem {
  id              String   @id @default(cuid())
  allowanceId     String
  allowance       EinvoiceAllowance @relation(fields: [allowanceId], references: [id], onDelete: Cascade)
  sequence        Int
  /** 對應原發票品項序號 */
  originalSequence Int?
  description     String
  quantity        Decimal  @db.Decimal(14, 4)
  unit            String?
  unitPrice       Decimal  @db.Decimal(14, 4)
  amount          Decimal  @db.Decimal(14, 2)
  taxType         String   @default("1")
  taxAmount       Decimal  @db.Decimal(14, 2)
}

// ============================================================
// Accounting (Phase A 最小可用會計)
// ============================================================
//
// 啟用前由 Tenant.settings.accounting.enabled = false 把整個模組關掉，
// 此時自動分錄 hooks 會 skip。ADMIN 在後台「會計」頁按「啟用」會：
//   1. flip enabled = true
//   2. 種子預設 30 個科目
//   3. 建立會計年度的 12 期間
//   4. 引導填期初餘額（單筆開帳分錄）
// 啟用後新發生的交易才會產自動分錄；歷史交易不補。

model ChartOfAccount {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /** 科目編號（4 位數，如 1101 現金） */
  code         String
  name         String
  /** 階層 1-4，預設範本最深到 2 */
  level        Int      @default(1)
  parentId     String?
  parent       ChartOfAccount?  @relation("AccountTree", fields: [parentId], references: [id])
  children     ChartOfAccount[] @relation("AccountTree")
  /** asset|liability|equity|income|cost|expense */
  type         String
  /** debit|credit — 該科目正常餘額方向，反向時餘額為負 */
  normalSide   String
  /** 系統預設科目（不可刪除，名稱可改） */
  isSystem     Boolean  @default(false)
  isActive     Boolean  @default(true)
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@index([tenantId, parentId])
}

model FiscalPeriod {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  year      Int
  /** 1-12，月份 */
  period    Int
  startDate DateTime
  endDate   DateTime
  /** open|closed — closed 後不可再過帳新分錄到此期間 */
  status    String   @default("open")
  closedAt  DateTime?
  closedBy  String?
  createdAt DateTime @default(now())

  journalEntries JournalEntry[]

  @@unique([tenantId, year, period])
  @@index([tenantId, status])
}

model JournalEntry {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /** 傳票編號 JE-YYYYMMDD-NNN */
  entryNo     String
  entryDate   DateTime
  periodId    String
  period      FiscalPeriod @relation(fields: [periodId], references: [id])
  description String
  /** manual|sales|purchase|receipt|payment|einvoice|opening|reversal */
  source      String   @default("manual")
  /** 對應原始單據 id（sales-order id / receivable id 等） */
  sourceId    String?
  /** pending|posted|reversed */
  status      String   @default("pending")
  postedAt    DateTime?
  postedBy    String?
  reversedAt  DateTime?
  reversedBy  String?
  /** 反沖傳票 id（status=reversed 時指向新建的紅字傳票） */
  reversedById String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalLine[]

  @@unique([tenantId, entryNo])
  @@index([tenantId, status])
  @@index([tenantId, entryDate])
  @@index([tenantId, source, sourceId])
}

model JournalLine {
  id          String   @id @default(cuid())
  entryId     String
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  sequence    Int
  accountId   String
  account     ChartOfAccount @relation(fields: [accountId], references: [id])
  /** 借方金額；非借方時 0 */
  debit       Decimal  @default(0) @db.Decimal(14, 2)
  /** 貸方金額；非貸方時 0 */
  credit      Decimal  @default(0) @db.Decimal(14, 2)
  description String?
  /** 部門 / 成本中心，Phase A 為 nullable，未來可加 Department 表 */
  departmentId String?

  @@index([entryId])
  @@index([accountId])
}
