generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

// ============================================================
// Multi-Tenant
// ============================================================

model Tenant {
  id                String   @id @default(cuid())
  companyName       String
  taxId             String?  // 統一編號
  lineChannelId     String?  @unique
  lineChannelSecret String?
  lineAccessToken   String?
  logo              String?
  address           String?
  phone             String?
  email             String?
  modules           String[] // ["sales","purchase","accounting"]
  settings          Json     @default("{}")
  isActive          Boolean  @default(true)
  // P1-1 churn：soft-delete 時戳。非 null = 已退租（保留資料，30 天後可 hard-delete）。
  // platform 列表預設過濾掉 deletedAt != null 的租戶。
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  employees      Employee[]
  products       Product[]
  customers      Customer[]
  suppliers      Supplier[]
  quotations     Quotation[]
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  receivables    AccountReceivable[]
  payables       AccountPayable[]
  auditLogs      AuditLog[]
  inventories    Inventory[]
  inventoryTxns  InventoryTransaction[]
  einvoices          Einvoice[]
  einvoiceNumberPools EinvoiceNumberPool[]
  allowances         EinvoiceAllowance[]
  chartOfAccounts    ChartOfAccount[]
  fiscalPeriods      FiscalPeriod[]
  journalEntries     JournalEntry[]
  visitLogs          VisitLog[]
  versionSubscription TenantVersionSubscription?
  billingSubscription TenantBillingSubscription?
  versionUpgradeLogs  VersionUpgradeLog[]
  billingSubLogs      BillingSubscriptionLog[]
}

// ============================================================
// Core: Employee & Auth
// ============================================================

model Employee {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  lineUserId String?
  employeeId String
  name       String
  phone      String?
  email      String?
  address    String?
  notes      String?  // 管理員備忘（v2.17.0+）
  role       Role     @default(VIEWER)
  // 業績獎金代開發票扣除稅率 %（v2.16.0+）。實發 = 累積獎金 × (1 − taxDeductRate/100)。
  // null / 0 = 不扣。每位業務各自設定。
  taxDeductRate Decimal? @db.Decimal(5, 2)
  // 銀行帳號資訊（v2.16.1+）— 薪轉 / 獎金匯款
  bankCode        String?  // 銀行代號（如 053）
  bankName        String?  // 銀行名稱（如 台中商銀）
  bankBranch      String?  // 分行（如 竹南分行）
  bankAccountName String?  // 戶名
  bankAccountNo   String?  // 匯款帳號
  // bcrypt hash for the admin web console. Null = no web access (LINE-only user).
  passwordHash String?
  // Timestamp when passwordHash was last set; surfaced in admin UI so ADMIN
  // can see which employees have a live web login and when it was last rotated.
  passwordSetAt DateTime?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  createdCustomers Customer[] @relation("CustomerCreatedBy")
  visitLogs        VisitLog[] @relation("VisitLogCreatedBy")

  @@unique([tenantId, employeeId])
  @@unique([tenantId, lineUserId])
  @@index([tenantId])
}

enum Role {
  ADMIN
  SALES
  PURCHASING
  ACCOUNTING
  VIEWER
}

// ============================================================
// Master: Product
// ============================================================

model Product {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  code      String
  name      String
  category  String?
  salePrice Decimal  @db.Decimal(12, 2)
  costPrice Decimal  @db.Decimal(12, 2)
  note      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory     Inventory?
  inventoryTxns InventoryTransaction[]
  documents     ProductDocument[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ============================================================
// Master: Product Documents (PDS / SDS / DM / etc.)
// ============================================================

model ProductDocument {
  id          String      @id @default(cuid())
  tenantId    String
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        DocumentType
  fileName    String      // original filename for display
  storagePath String      // legacy (was Supabase path); kept for backward compat
  fileSize    Int         // bytes
  mimeType    String
  fileData    Bytes?      // v2.16.0+: file content in DB (replaces Supabase Storage)
  uploadedBy  String?     // employee id
  createdAt   DateTime    @default(now())

  @@index([tenantId])
  @@index([productId, type])
}

enum DocumentType {
  PDS
  SDS
  DM
  OTHER
}

// ============================================================
// Master: Customer
// ============================================================

model Customer {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  contactName String?
  // 聯絡人職稱（如「業務經理」「總經理」「研發專員」），v2.10.0+
  // 從名片抽出避免跟姓名搞混；空字串 / null 視為未填。
  title       String?
  taxId       String?
  phone       String?
  zipCode     String?
  address     String?
  paymentDays Int      @default(30)
  // 結帳日 1-31（31 視為月底）。決定銷貨日落在哪個結帳月：
  //   訂單日.day ≤ statementDay → 本月結；否則下月結。
  // null → fallback 視為 31。
  statementDay        Int?
  // 固定付款日 1-31。decision dueDate 的日；若 fixedPaymentDay > 該月最後一日則 clamp。
  // null → fallback 走月底（沿用舊行為）。
  fixedPaymentDay     Int?
  // 'check' 開票 / 'cash' 現金 / 'transfer' 轉帳。null = 未指定。
  paymentMethod       String?
  // FK 至 Employee（業務員）。新欄位，與舊 `createdBy String?` 並存以避免 mixed-version；
  // 寫入時兩邊同步，讀取優先用此 FK。v2.9.x 後可淘汰舊欄位。
  createdByEmployeeId String?
  createdByEmployee   Employee? @relation("CustomerCreatedBy", fields: [createdByEmployeeId], references: [id])
  lineUserId  String?
  email       String?
  // 匯款銀行資料（客戶付款進來，僅供入帳對帳識別），v2.14.0+
  // 只存末五碼：銀行對帳單僅顯示匯入帳號末五碼，不需完整帳號。
  bankCode         String?  // 銀行代號 3 碼
  bankName         String?  // 銀行名稱
  bankAccountLast5 String?  // 匯款帳號末五碼
  grade       String?  @default("B") // A/B/C
  tags        String[] // industry tags
  // 舊欄位：Employee id 字串，無 FK。為相容暫留。
  createdBy   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotations  Quotation[]
  salesOrders SalesOrder[]
  receivables AccountReceivable[]
  visitLogs   VisitLog[]

  @@unique([tenantId, name])
  @@unique([tenantId, lineUserId])
  @@index([tenantId])
  @@index([tenantId, createdByEmployeeId])
}

// ============================================================
// Master: Supplier
// ============================================================

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  type        String?
  contactName String?
  taxId       String?
  phone       String?
  zipCode     String?
  address     String?
  paymentDays Int      @default(60)
  email       String?
  // 匯款帳戶（付款給供應商用，需完整資訊），v2.14.0+
  bankCode        String?  // 銀行代號 3 碼
  bankName        String?  // 銀行名稱
  bankBranch      String?  // 分行名稱
  bankAccount     String?  // 完整匯款帳號
  bankAccountName String?  // 戶名
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  payables       AccountPayable[]
  documents      SupplierDocument[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ============================================================
// Master: Supplier Documents (銀行存摺 / 合約 / 其他)
// ============================================================

enum SupplierDocumentType {
  BANKBOOK // 銀行存摺
  CONTRACT // 合約
  OTHER
}

model SupplierDocument {
  id          String               @id @default(cuid())
  tenantId    String
  supplierId  String
  supplier    Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type        SupplierDocumentType
  fileName    String               // 顯示用原始檔名
  storagePath String               // legacy (was Supabase path); kept for backward compat
  fileSize    Int                  // bytes
  mimeType    String
  fileData    Bytes?               // v2.16.0+: file content in DB (replaces Supabase Storage)
  uploadedBy  String?              // employee id
  createdAt   DateTime             @default(now())

  @@index([tenantId])
  @@index([supplierId, type])
}

// ============================================================
// Sales: Quotation + Tracking
// ============================================================

model Quotation {
  id             String          @id @default(cuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  quotationNo    String
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  salesPerson    String
  salesPhone     String?
  subtotal       Decimal         @db.Decimal(12, 2)
  taxAmount      Decimal         @db.Decimal(12, 2)
  totalAmount    Decimal         @db.Decimal(12, 2)
  supplyTime     String?
  paymentTerms   String?
  validUntil     String?
  note           String?
  status         QuotationStatus @default(DRAFT)
  dealClosed     Boolean?
  trackingNote   String?
  version        Int             @default(1)
  createdBy      String
  isDeleted      Boolean         @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items      QuotationItem[]
  salesOrder SalesOrder?

  @@unique([tenantId, quotationNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, isDeleted])
}

model QuotationItem {
  id             String   @id @default(cuid())
  quotationId    String
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productName    String
  quantity       Int
  unitPrice      Decimal  @db.Decimal(12, 2)
  amount         Decimal  @db.Decimal(12, 2)
  note           String?
  suggestedPrice Decimal? @db.Decimal(12, 2)
  sortOrder      Int      @default(0)
}

enum QuotationStatus {
  DRAFT
  SENT
  TRACKING
  WON
  LOST
  CANCELLED
}

// ============================================================
// Sales: Sales Order + Record
// ============================================================

model SalesOrder {
  id           String      @id @default(cuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  orderNo      String
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  quotationId  String?     @unique
  quotation    Quotation?  @relation(fields: [quotationId], references: [id])
  salesPerson  String
  salesPhone   String?
  deliveryNote String?
  subtotal     Decimal     @db.Decimal(12, 2)
  taxAmount    Decimal     @db.Decimal(12, 2)
  totalAmount  Decimal     @db.Decimal(12, 2)
  status       SalesStatus @default(PENDING)
  orderDate    DateTime    @default(now())
  deliveryDate DateTime?
  deliveredBy  String?
  receivedBy   String?
  /**
   * 電子發票載具/捐贈預填欄位（v2.12.0+）。LINE B2C 流程收集，後續開立發票時自動帶入。
   * einvoiceCarrierType: 3J0002=手機條碼 CQ0001=自然人憑證 EJ0113=會員載具（依財政部）
   * einvoiceNpoban: 3-7 碼數字捐贈碼
   * einvoicePrintFlag: Y=列印證明聯 N=不列印（載具/捐贈時通常 N）
   * 全為 null = B2B 情境，發票走預設（列印 + 無載具）。
   */
  einvoiceCarrierType String?
  einvoiceCarrierId   String?
  einvoiceNpoban      String?
  einvoicePrintFlag   String?
  createdBy    String
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items      SalesItem[]
  receivable AccountReceivable?
  einvoices  Einvoice[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, isDeleted])
}

model SalesItem {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productName  String
  quantity     Int
  unitPrice    Decimal    @db.Decimal(12, 2)
  amount       Decimal    @db.Decimal(12, 2)
  // 成交當下的產品售價快照（v2.15.0+，保留供參考）。
  salePriceAtSale Decimal? @db.Decimal(12, 2)
  // 成交當下的產品進價快照（v2.16.0+）。業績獎金 =（unitPrice − costAtSale）× quantity − 營業稅。
  // 歷史資料或自由輸入品名（無對應產品）為 null → 報表 fallback 用當前 Product.costPrice。
  costAtSale   Decimal? @db.Decimal(12, 2)
  note         String?
  sortOrder    Int        @default(0)
}

enum SalesStatus {
  PENDING
  DELIVERED
  COMPLETED
}

// ============================================================
// Purchase: Purchase Order + Record
// ============================================================

model PurchaseOrder {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  orderNo       String
  supplierId    String
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  internalStaff String
  staffPhone    String?
  deliveryNote  String?
  subtotal      Decimal        @db.Decimal(12, 2)
  taxAmount     Decimal        @db.Decimal(12, 2)
  totalAmount   Decimal        @db.Decimal(12, 2)
  status        PurchaseStatus @default(PENDING)
  orderDate     DateTime       @default(now())
  receivedDate  DateTime?
  createdBy     String
  isDeleted     Boolean        @default(false)
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  items   PurchaseItem[]
  payable AccountPayable?

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, supplierId])
  @@index([tenantId, isDeleted])
}

model PurchaseItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productName      String
  quantity         Int
  unitPrice        Decimal       @db.Decimal(12, 2)
  amount           Decimal       @db.Decimal(12, 2)
  note             String?
  referenceCost    Decimal?      @db.Decimal(12, 2)
  lastPurchaseDate DateTime?
  sortOrder        Int           @default(0)
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  COMPLETED
}

// ============================================================
// Accounting: Accounts Receivable
// ============================================================

model AccountReceivable {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id])
  salesOrderId String     @unique
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  billingMonth Int
  billingYear  Int
  amount       Decimal    @db.Decimal(12, 2)
  dueDate      DateTime
  isPaid       Boolean    @default(false)
  paidDate     DateTime?
  invoiceNo    String?
  note         String?
  einvoice     Einvoice?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId])
  @@index([tenantId, isPaid])
  @@index([tenantId, dueDate])
}

// ============================================================
// Accounting: Accounts Payable
// ============================================================

model AccountPayable {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id])
  purchaseOrderId String        @unique
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  billingMonth    Int
  billingYear     Int
  amount          Decimal       @db.Decimal(12, 2)
  dueDate         DateTime
  isPaid          Boolean       @default(false)
  paidDate        DateTime?
  invoiceNo       String?
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([tenantId, isPaid])
  @@index([tenantId, dueDate])
}

// ============================================================
// Core: Audit Log
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String
  action    String
  entity    String
  entityId  String
  detail    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, entity, entityId])
  @@index([createdAt])
}

// ============================================================
// Inventory
// ============================================================

model Inventory {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  productId     String   @unique
  product       Product  @relation(fields: [productId], references: [id])
  quantity      Int      @default(0)
  reorderPoint  Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, productId])
  @@index([tenantId])
  @@index([tenantId, productId])
}

model InventoryTransaction {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  productId String
  product   Product           @relation(fields: [productId], references: [id])
  delta     Int
  reason    InventoryReason
  refType   String?
  refId     String?
  note      String?
  createdBy String?
  createdAt DateTime          @default(now())

  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, refType, refId])
}

enum InventoryReason {
  SALES_OUT
  PURCHASE_IN
  ADJUSTMENT
  INITIAL
}

// ============================================================
// Short Links (for LINE-friendly download URLs)
// ============================================================

// A short opaque code that resolves to a full download URL. Lets us
// send "https://host/s/AX7B2K" in LINE instead of 150-char JWT links.
// The target is stored as-is (e.g. a /pdf/:kind/:id?token=... URL);
// /s/:code simply 302-redirects to it. The underlying JWT still guards
// the resource, so short-link rows themselves are not secrets.
model ShortLink {
  id        String    @id @default(cuid())
  code      String    @unique
  tenantId  String?
  target    String    @db.Text
  label     String?
  kind      String?
  expiresAt DateTime?
  hits      Int       @default(0)
  createdBy String?
  createdAt DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([expiresAt])
}

// ============================================================
// Error Log (runtime exceptions, surfaced in admin "異常紀錄")
// ============================================================

model ErrorLog {
  id         String   @id @default(cuid())
  tenantId   String?                      // null for pre-auth errors
  userId     String?                      // null for anonymous / cron
  level      String   @default("error")   // error | warn
  source     String                       // "line.webhook", "api.products", "pdf.router", ...
  message    String   @db.Text
  stack      String?  @db.Text
  requestId  String?                      // correlation id (if set by middleware)
  route      String?                      // e.g. "POST /api/products"
  statusCode Int?
  context    Json?                        // arbitrary structured extras
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@index([level, createdAt])
}

// ============================================================
// E-Invoice (Taiwan 財政部電子發票 MIG 3.2.1 via Turnkey)
// ============================================================

// 電子發票字軌 / 配號區間。每兩個月一批，由 ADMIN 從國稅局核定通知書
// 複製進來。`nextNumber` 於 `allocateNumber()` 交易內遞增；耗盡時
// `nextNumber > rangeEnd`，isActive 自動停用由呼叫方處理。
model EinvoiceNumberPool {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  yearMonth   String   // 7 碼 民國年 3 + 單月 2 + 雙月 2 e.g. "1131112" = 民國 113 年 11-12 月期
  trackAlpha  String   // 字軌兩碼 e.g. "AB"
  rangeStart  Int      // 00000000 - 99999999
  rangeEnd    Int
  nextNumber  Int
  isActive    Boolean  @default(true)
  /** 分支機構（總公司=null）。預留欄位，無對應 Branch FK；用於分店字軌隔離。 */
  branchId    String?
  note        String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, isActive])
  @@index([tenantId, yearMonth, branchId])
}

// 單張電子發票主檔。與 AccountReceivable 1:1、SalesOrder N:1（同一銷貨單
// 在作廢後可重開一張，故 salesOrderId 不 unique；receivableId unique）。
model Einvoice {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceNo     String    // "AB12345678"
  invoiceDate   DateTime
  buyerTaxId    String?   // null → XML 輸出時填 "0000000000"
  buyerName     String
  buyerAddress  String?
  salesAmount   Decimal   @db.Decimal(14, 2)
  taxAmount     Decimal   @db.Decimal(14, 2)
  totalAmount   Decimal   @db.Decimal(14, 2)
  taxType       String    @default("1") // 1=應稅 2=零稅率 3=免稅
  status        String    @default("issued") // issued|uploaded|confirmed|rejected|voided
  voidedAt      DateTime?
  voidReason    String?
  xmlPath       String?   // 寫到 Turnkey inbound 目錄後的檔名（絕對路徑）
  voidXmlPath   String?
  /** XML 內容存 DB 第二份，避免 Turnkey 主機毀損時 metadata 對不到原始 XML（項 11） */
  xmlBody       String?   @db.Text
  voidXmlBody   String?   @db.Text
  /** 分支機構（總公司=null）；對應 EinvoiceNumberPool.branchId */
  branchId      String?
  /** MIG 4.1 新增：總備註 (200 字內)。寫入 XML <MainRemark>。 */
  mainRemark    String?
  /** MIG 4.1 新增：通關方式 "1"=非經海關出口 "2"=經海關出口；零稅率必填。 */
  customsClearanceMark String?
  /** MIG 4.1 新增：零稅率原因（搭配 taxType=2） */
  zeroTaxRateReason    String?
  uploadedAt    DateTime?
  confirmedAt   DateTime?
  rejectReason  String?

  receivableId  String?   @unique
  receivable    AccountReceivable? @relation(fields: [receivableId], references: [id])
  salesOrderId  String?
  salesOrder    SalesOrder? @relation(fields: [salesOrderId], references: [id])

  items         EinvoiceItem[]
  allowances    EinvoiceAllowance[]
  /** 4 碼隨機碼，B2C 證明聯 QR 驗證會用到 */
  randomCode    String?
  /** 載具類別代碼：3J0002=手機條碼 CQ0001=自然人憑證 EJ0113=會員載具（依財政部） */
  carrierType   String?
  /** 載具 ID（手機條碼 8 碼 / 憑證 16 碼 / 會員自訂） */
  carrierId     String?
  /** 捐贈碼（3-7 碼數字）— NPOBAN */
  npoban        String?
  /** 列印註記 Y=列印證明聯 N=不列印（載具或捐贈時 N） */
  printFlag     String   @default("Y")
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, status])
  @@index([tenantId, invoiceDate])
}

model EinvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Einvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sequence    Int
  description String
  quantity    Decimal  @db.Decimal(14, 4)
  unit        String?
  unitPrice   Decimal  @db.Decimal(14, 4)
  amount      Decimal  @db.Decimal(14, 2)
}

// 折讓單 D0401（賣方開立）/ D0501（賣方作廢折讓）。
// 一張電子發票可對應多張折讓單（部分折讓）。
model EinvoiceAllowance {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  allowanceNo     String   // 折讓單號（自訂 YYYYMMDD + seq）
  allowanceDate   DateTime
  /** seller=賣方開立 buyer=買方開立（本系統目前只做 seller） */
  type            String   @default("seller")
  invoiceId       String
  invoice         Einvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  salesAmount     Decimal  @db.Decimal(14, 2)
  taxAmount       Decimal  @db.Decimal(14, 2)
  totalAmount     Decimal  @db.Decimal(14, 2)
  reason          String?
  status          String   @default("issued") // issued|confirmed|voided
  xmlPath         String?
  voidXmlPath     String?
  voidedAt        DateTime?
  voidReason      String?
  items           EinvoiceAllowanceItem[]
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, allowanceNo])
  @@index([tenantId, status])
  @@index([invoiceId])
}

model EinvoiceAllowanceItem {
  id              String   @id @default(cuid())
  allowanceId     String
  allowance       EinvoiceAllowance @relation(fields: [allowanceId], references: [id], onDelete: Cascade)
  sequence        Int
  /** 對應原發票品項序號 */
  originalSequence Int?
  description     String
  quantity        Decimal  @db.Decimal(14, 4)
  unit            String?
  unitPrice       Decimal  @db.Decimal(14, 4)
  amount          Decimal  @db.Decimal(14, 2)
  taxType         String   @default("1")
  taxAmount       Decimal  @db.Decimal(14, 2)
}

// ============================================================
// Accounting (Phase A 最小可用會計)
// ============================================================
//
// 啟用前由 Tenant.settings.accounting.enabled = false 把整個模組關掉，
// 此時自動分錄 hooks 會 skip。ADMIN 在後台「會計」頁按「啟用」會：
//   1. flip enabled = true
//   2. 種子預設 30 個科目
//   3. 建立會計年度的 12 期間
//   4. 引導填期初餘額（單筆開帳分錄）
// 啟用後新發生的交易才會產自動分錄；歷史交易不補。

model ChartOfAccount {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /** 科目編號（4 位數，如 1101 現金） */
  code         String
  name         String
  /** 階層 1-4，預設範本最深到 2 */
  level        Int      @default(1)
  parentId     String?
  parent       ChartOfAccount?  @relation("AccountTree", fields: [parentId], references: [id])
  children     ChartOfAccount[] @relation("AccountTree")
  /** asset|liability|equity|income|cost|expense */
  type         String
  /** debit|credit — 該科目正常餘額方向，反向時餘額為負 */
  normalSide   String
  /** 系統預設科目（不可刪除，名稱可改） */
  isSystem     Boolean  @default(false)
  isActive     Boolean  @default(true)
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@index([tenantId, parentId])
}

model FiscalPeriod {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  year      Int
  /** 1-12，月份 */
  period    Int
  startDate DateTime
  endDate   DateTime
  /** open|closed — closed 後不可再過帳新分錄到此期間 */
  status    String   @default("open")
  closedAt  DateTime?
  closedBy  String?
  createdAt DateTime @default(now())

  journalEntries JournalEntry[]

  @@unique([tenantId, year, period])
  @@index([tenantId, status])
}

model JournalEntry {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /** 傳票編號 JE-YYYYMMDD-NNN */
  entryNo     String
  entryDate   DateTime
  periodId    String
  period      FiscalPeriod @relation(fields: [periodId], references: [id])
  description String
  /** manual|sales|purchase|receipt|payment|einvoice|opening|reversal */
  source      String   @default("manual")
  /** 對應原始單據 id（sales-order id / receivable id 等） */
  sourceId    String?
  /** pending|posted|reversed */
  status      String   @default("pending")
  postedAt    DateTime?
  postedBy    String?
  reversedAt  DateTime?
  reversedBy  String?
  /** 反沖傳票 id（status=reversed 時指向新建的紅字傳票） */
  reversedById String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalLine[]

  @@unique([tenantId, entryNo])
  @@index([tenantId, status])
  @@index([tenantId, entryDate])
  @@index([tenantId, source, sourceId])
}

model JournalLine {
  id          String   @id @default(cuid())
  entryId     String
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  sequence    Int
  accountId   String
  account     ChartOfAccount @relation(fields: [accountId], references: [id])
  /** 借方金額；非借方時 0 */
  debit       Decimal  @default(0) @db.Decimal(14, 2)
  /** 貸方金額；非貸方時 0 */
  credit      Decimal  @default(0) @db.Decimal(14, 2)
  description String?
  /** 部門 / 成本中心，Phase A 為 nullable，未來可加 Department 表 */
  departmentId String?

  @@index([entryId])
  @@index([accountId])
}

// ============================================================
// CRM: Visit Log (業務拜訪/工作日誌)
// ============================================================
//
// 業務員每次拜訪客戶的記錄。LINE chat（手機端）與後台都能填。
// SALES 角色只看自己 createdByEmployeeId 的紀錄；ADMIN/ACCOUNTING/VIEWER 看全租戶。
// nextActionDate 為「下次行動 / 追蹤日」，預留給後續提醒 cron 用。

model VisitLog {
  id                  String    @id @default(cuid())
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  visitDate           DateTime  @db.Date
  customerId          String
  customer            Customer  @relation(fields: [customerId], references: [id])
  content             String    @db.Text
  nextActionDate      DateTime? @db.Date
  createdByEmployeeId String?
  createdByEmployee   Employee? @relation("VisitLogCreatedBy", fields: [createdByEmployeeId], references: [id])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([tenantId, visitDate])
  @@index([tenantId, customerId])
  @@index([tenantId, createdByEmployeeId])
}

// ============================================================
// Version Management (P0-3a)
// ============================================================

model VersionHistory {
  id             String   @id @default(cuid())
  version        String   @unique // e.g. "2.5.0"
  releaseDate    DateTime @default(now())
  supportedUntil DateTime // 30天後自動升級所有租戶
  features       String[] @default([]) // 新功能列表
  notes          String?  @db.Text // 發版說明
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([releaseDate])
  @@index([supportedUntil])
}

model TenantVersionSubscription {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currentVersion  String   // 當前版本
  previousVersion String?  // 上一版本（供 rollback 使用）
  latestVersion   String   // 最新可用版本
  upgradeDeadline DateTime? // 租戶必須升級的期限（30天後自動升級）
  lastCheckedAt   DateTime?
  lastUpgradedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([upgradeDeadline])
}

enum VersionChangeType {
  UPGRADE
  ROLLBACK
  AUTO_UPGRADE
}

model VersionUpgradeLog {
  id            String            @id @default(cuid())
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromVersion   String
  toVersion     String
  changeType    VersionChangeType
  operatorId    String?           // 執行者 employeeId（AUTO_UPGRADE 時為 null）
  reason        String?           @db.Text
  // CP（控制台）pull-on-demand 升級成功後 push 的 git commit SHA（P0-V）。
  // ERP 自身 semver 升級為 null；讓 CP 的 deploy commit 追蹤能與 ERP semver 對齊。
  commitHash    String?
  createdAt     DateTime          @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([changeType])
}

// ============================================================
// Billing Management (P0-3b)
// ============================================================

enum BillingCycle {
  MONTHLY
  ANNUALLY
}

enum BillingEventType {
  SUBSCRIPTION_CREATED
  PLAN_UPGRADE
  PLAN_DOWNGRADE
  RENEWAL
  CANCELLATION
  TRIAL_END
  SUSPENSION      // P0-3c: 訂閱暫停
  RESUME          // P0-3c: 訂閱恢復
  OVERDUE_NOTICE  // P0-3c: 逾期通知
  USAGE_OVERAGE   // P0-3c: 使用量超額
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

model BillingPlan {
  id                      String   @id @default(cuid())
  name                    String   @unique // e.g., "Pro", "Enterprise"
  description             String?  @db.Text
  monthlyPrice            Decimal  @db.Decimal(10, 2)
  annualPrice             Decimal  @db.Decimal(10, 2)
  initialSetupPrice       Decimal  @default(0) @db.Decimal(10, 2) // P0-3c: 首次設計費
  yearlyPrice             Decimal? @db.Decimal(10, 2) // P0-3c: 年繳價格
  yearlyDiscountPercent   Decimal  @default(0) @db.Decimal(5, 2) // P0-3c: 年繳折扣百分比
  trialDays               Int      @default(14) // 試用期天數
  isActive                Boolean  @default(true)
  displayOrder            Int      @default(0) // 展示順序
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  planFeatures            PlanFeature[]
  subscriptions           TenantBillingSubscription[]
  usageLimits             UsageLimit[]
  usageOverageRates       UsageOverageRate[]

  @@index([isActive])
  @@index([displayOrder])
}

model PlanFeature {
  id        String   @id @default(cuid())
  planId    String
  plan      BillingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature   String   // 功能名稱（e.g., "inventory", "accounting", "commission"）
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([planId, feature])
  @@index([planId])
}

model TenantBillingSubscription {
  id                  String         @id @default(cuid())
  tenantId            String         @unique
  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId              String
  plan                BillingPlan    @relation(fields: [planId], references: [id])
  billingCycle        BillingCycle   @default(MONTHLY)
  isInTrial           Boolean        @default(true)
  trialEndDate        DateTime?
  subscriptionStart   DateTime       @default(now())
  renewalDate         DateTime       @default(now()) // 下次續訂日期
  autoRenew           Boolean        @default(true)
  cancellationDate    DateTime?      // 租戶取消訂閱日期
  setupFeeCharged     Boolean        @default(false) // P0-3c: 是否已收首次設計費
  suspendedAt         DateTime?      // P0-3c: 暫停時間
  suspendedUntil      DateTime?      // P0-3c: 暫停結束日期
  suspendReason       String?        // P0-3c: 暫停原因
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  billingEvents       BillingEvent[]
  invoices            Invoice[]
  usageMetrics        UsageMetric[]

  @@index([tenantId])
  @@index([planId])
  @@index([renewalDate])
  @@index([isInTrial])
  @@index([suspendedAt])
}

model BillingEvent {
  id                    String                      @id @default(cuid())
  subscriptionId        String
  subscription          TenantBillingSubscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  eventType             BillingEventType
  oldPlanId             String?                     // Plan 升降級時的舊 Plan
  newPlanId             String?                     // Plan 升降級時的新 Plan
  effectiveDate         DateTime                    @default(now())
  proratedAmount        Decimal?                    @db.Decimal(10, 2) // 按比例調整金額
  description           String?
  createdAt             DateTime                    @default(now())

  @@index([subscriptionId])
  @@index([eventType])
  @@index([effectiveDate])
}

model BillingSubscriptionLog {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  action        String   // PLAN_CHANGE | CYCLE_CHANGE | SUSPEND | RESUME | CANCEL | REACTIVATE
  fromPlanId    String?  // 舊方案 ID
  fromPlanName  String?  // 舊方案名稱（快照，避免方案改名後查不到）
  toPlanId      String?  // 新方案 ID
  toPlanName    String?  // 新方案名稱
  operatorId    String?  // 操作者 employeeId
  reason        String?  @db.Text
  metadata      Json?    // 額外資訊（如 billingCycle 變更前後值）
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([action])
}

model Invoice {
  id                    String                       @id @default(cuid())
  invoiceNumber         String                       @unique
  subscriptionId        String
  subscription          TenantBillingSubscription    @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  billingPeriodStart    DateTime
  billingPeriodEnd      DateTime
  amount                Decimal                      @db.Decimal(10, 2)
  discount              Decimal                      @default(0)                         @db.Decimal(10, 2)
  tax                   Decimal                      @default(0)                         @db.Decimal(10, 2)
  total                 Decimal                      @db.Decimal(10, 2)
  status                InvoiceStatus                @default(DRAFT)
  issuedAt              DateTime?
  paidAt                DateTime?
  dueDate               DateTime
  overdueSince          DateTime?                    // P0-3c: 逾期開始時間
  reminderSentAt        DateTime?                    // P0-3c: 催款通知寄送時間
  overdueFeeApplied     Decimal                      @default(0) @db.Decimal(10, 2) // P0-3c: 逾期費
  notes                 String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  @@unique([subscriptionId, billingPeriodStart])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@index([issuedAt])
  @@index([overdueSince])
}

// ============================================================
// Usage-Based Billing (P0-3c)
// ============================================================

model UsageMetric {
  id             String                       @id @default(cuid())
  subscriptionId String
  subscription   TenantBillingSubscription    @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  metricType     String // e.g., "api_calls", "storage_gb", "user_count"
  value          Decimal                      @db.Decimal(12, 2)
  recordedAt     DateTime                     @default(now())
  createdAt      DateTime                     @default(now())

  @@index([subscriptionId, metricType])
  @@index([recordedAt])
}

model UsageLimit {
  id            String      @id @default(cuid())
  planId        String
  plan          BillingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  metricType    String // e.g., "api_calls", "storage_gb", "user_count"
  monthlyLimit  Decimal     @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([planId, metricType])
  @@index([planId])
}

model UsageOverageRate {
  id           String      @id @default(cuid())
  planId       String
  plan         BillingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  metricType   String // e.g., "api_calls", "storage_gb", "user_count"
  ratePerUnit  Decimal     @db.Decimal(10, 4) // 每單位超額費用
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([planId, metricType])
  @@index([planId])
}
